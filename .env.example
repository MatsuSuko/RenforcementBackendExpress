PORT=3000

# ─── Base de données ──────────────────────────────────────────────────────────
# Ces valeurs doivent correspondre à celles définies dans docker-compose.yml
DB_USERNAME=root
DB_PASSWORD=root
DB_HOST=db          # Nom du service Docker (ne pas changer si vous utilisez Docker Compose)
DB_PORT=3306
DB_NAME=assurmoidb

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT — changez-la impérativement en production !
SECRET_KEY=change_this_secret_in_production

# ─── Bcrypt ──────────────────────────────────────────────────────────────────
# Nombre de rounds pour le hachage des mots de passe (10 = bon équilibre sécurité/perf)
BCRYPT_SALT=10

# ─── Mail ────────────────────────────────────────────────────────────────────
# Deux options : Mailhog (dev local) ou SMTP réel (Gmail, etc.)
#
# Option 1 — Mailhog (Docker, aucune config requise) :
#   MAIL_HOST=mailhog
#   MAIL_PORT=1025
#   MAIL_SECURE=false
#   # Laisser MAIL_USER et MAIL_PASS vides
#   MAIL_FROM=noreply@assurmoi.fr
#
# Option 2 — Gmail SMTP (production / test réel) :
#   1. Activez la validation en 2 étapes sur votre compte Google
#   2. Créez un "Mot de passe d'application" sur https://myaccount.google.com/apppasswords
#   3. Utilisez ce mot de passe de 16 caractères dans MAIL_PASS (pas votre vrai mot de passe)
#
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@assurmoi.fr

# ─── URL de l'application ─────────────────────────────────────────────────────
# Utilisée dans les liens des emails (réinitialisation de mot de passe, etc.)
APP_URL=http://localhost:3000
