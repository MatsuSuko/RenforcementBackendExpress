PORT=3000

# Base de données
DB_USERNAME=root
DB_PASSWORD=root
DB_HOST=db
DB_PORT=3306
DB_NAME=assurmoidb

# JWT
SECRET_KEY=change_this_secret_in_production

# Bcrypt
BCRYPT_SALT=10

# ─── Mail ────────────────────────────────────────────────────────────────────
# Mode dev avec Mailhog (Docker) : laisser les valeurs par défaut ci-dessous
# Mode prod avec un vrai SMTP (ex: Gmail) : remplir MAIL_USER et MAIL_PASS

MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_SECURE=false
# MAIL_USER=ton.email@gmail.com
# MAIL_PASS=ton_mot_de_passe_application
MAIL_FROM=noreply@assurmoi.fr

# URL de l'app
APP_URL=http://localhost:3000
